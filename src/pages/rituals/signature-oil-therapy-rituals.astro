---
import Layout from "../../layouts/Layout.astro";
import { CONTACT } from "../../constants/contact";
import oilImage from "../../assets/images/oil.png";
const therapies = [
  {
    title: "Sakura Swedish Flow",
    description:
      "Gentle, flowing strokes using warm oils to improve circulation and create deep physical and mental relaxation.",
    prices: [
      { duration: "60 Min", price: "₹2,299" },
      { duration: "90 Min", price: "₹3,499" },
    ],
  },
  {
    title: "Kanso Balinese Harmony",
    description:
      "A graceful fusion of long strokes and gentle acupressure with warm oils to balance body energy and induce deep calm.",
    prices: [
      { duration: "60 Min", price: "₹2,299" },
      { duration: "90 Min", price: "₹3,499" },
    ],
  },
  {
    title: "Onsen Warm Oil Therapy",
    description:
      "Warm herbal oils soothe tired muscles, improve blood flow, and provide a comforting, spa-like onsen experience.",
    prices: [
      { duration: "60 Min", price: "₹2,499" },
      { duration: "90 Min", price: "₹3,699" },
    ],
  },
  {
    title: "Takumi Deep Muscle Therapy",
    description:
      "A skilled deep-pressure oil massage designed to release chronic muscle tension and restore strength and flexibility.",
    prices: [
      { duration: "60 Min", price: "₹2,799" },
      { duration: "90 Min", price: "₹3,999" },
    ],
  },
  {
    title: "Shanti Stress Relief Therapy",
    description:
      "A deeply relaxing oil massage focused on relieving mental fatigue, emotional stress, and everyday tension.",
    prices: [
      { duration: "60 Min", price: "₹2,799" },
      { duration: "90 Min", price: "₹3,999" },
    ],
  },
  {
    title: "Kaizen Muscle Recovery Massage",
    description:
      "A restorative oil therapy designed to ease soreness, enhance flexibility, and support faster muscle recovery.",
    prices: [
      { duration: "60 Min", price: "₹2,799" },
      { duration: "90 Min", price: "₹3,999" },
    ],
  },
];
---

<Layout title="Signature Oil Therapies | Immerse in Warmth">
  <section
    class="pt-40 pb-20 bg-charcoal-900 border-b border-white/5 relative overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-gradient-to-tr from-charcoal-800 to-charcoal-900 z-0"
    >
    </div>
    <div
      class="absolute right-0 bottom-0 w-64 h-64 bg-gold-muted/10 rounded-tl-full blur-3xl"
    >
    </div>
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10 fade-in">
      <a
        href={`${import.meta.env.BASE_URL}rituals`}
        class="text-gold-muted text-sm uppercase tracking-widest hover:text-white transition-colors mb-8 inline-block"
        >&larr; Back to Rituals</a
      >
      <h1
        class="text-5xl md:text-6xl font-serif text-white mb-6 tracking-wider"
      >
        Signature Oil Therapies
      </h1>
      <p class="text-xl text-white/60 font-light">
        The art of flow. Warm herbal oils meet skilled 'Takumi' touch.
      </p>
    </div>
  </section>

  <section class="py-24 bg-cream text-charcoal-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left Side: Base Image -->
        <div
          class="relative h-[50vh] lg:h-auto bg-charcoal-900 overflow-hidden shadow-2xl lg:sticky lg:top-24 lg:self-start lg:min-h-[80vh]"
        >
          <img
            src={oilImage.src}
            alt="Signature Oil Therapies"
            class="absolute inset-0 w-full h-full object-cover opacity-80"
          />
        </div>

        <!-- Right Side: Treatments Menu -->
        <div class="space-y-16">
          {
            therapies.map((therapy) => (
              <div class="fade-in border-b border-charcoal-900/10 pb-12 last:border-0 last:pb-0">
                <h2 class="text-3xl font-serif mb-4 uppercase tracking-wider">
                  {therapy.title}
                </h2>

                <p class="text-lg font-light leading-relaxed text-charcoal-800 mb-8">
                  {therapy.description}
                </p>

                <div class="flex flex-wrap gap-4">
                  {therapy.prices.map((p) => (
                    <a
                      href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20the%20${encodeURIComponent(therapy.title)}%20(${encodeURIComponent(p.duration)}%20-%20${encodeURIComponent(p.price)}).`}
                      class="group relative border border-charcoal-900/20 bg-transparent hover:border-gold-muted transition-colors overflow-hidden flex items-center px-6 py-3 cursor-pointer justify-center"
                    >
                      <div class="absolute inset-0 bg-gold-muted/5 translate-y-full group-hover:translate-y-0 transition-transform duration-300" />

                      <div class="relative z-10 flex items-center gap-3">
                        <span class="block text-sm tracking-wider uppercase text-charcoal-800/80">
                          {p.duration}
                        </span>
                        <span class="w-1 h-1 rounded-full bg-gold-muted/50" />
                        <span class="block text-sm tracking-wider uppercase text-charcoal-800/80">
                          {p.price}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '../styles/global.css';
import { Menu, X } from 'lucide-astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Premium Japanese Wellness & Spa Experience" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/main-website/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Kiyora Wellness</title>
    <meta name="description" content={description} />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Header -->
    <header class="fixed w-full z-50 transition-all duration-300 bg-charcoal-900/90 backdrop-blur-md border-b border-white/5">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/main-website/" class="text-3xl font-serif text-white tracking-widest uppercase">
          Kiyora
        </a>
        
        <!-- Desktop Nav -->
        <nav class="hidden md:flex gap-8 items-center">
          <a href="/main-website/" class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors">Home</a>
          <a href="/main-website/menu" class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors">Rituals</a>
          <a href="/main-website/partnerships" class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors">B2B</a>
          <a href="https://wa.me/1234567890?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20a%20luxury%20treatment." 
             target="_blank" 
             rel="noopener noreferrer" 
             class="px-6 py-2 border border-gold-muted text-gold-muted hover:bg-gold-muted hover:text-charcoal-900 transition-colors uppercase text-sm tracking-widest">
            Book
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-charcoal-800 border-t border-white/5 pt-16 pb-8">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
        <div>
          <h3 class="text-2xl font-serif mb-4 text-white tracking-widest">KIYORA</h3>
          <p class="text-white/60 text-sm leading-relaxed font-light">
            Rooted in the Japanese concept of 'Ki'. We balance spirit, clear the mind, and restore inner harmony through the art of Takumi.
          </p>
        </div>
        <div>
          <h4 class="text-lg font-serif mb-4 text-white">Experience</h4>
          <ul class="space-y-2 text-sm text-white/60 font-light">
            <li><a href="/main-website/menu" class="hover:text-gold-muted transition-colors">Spa Menu</a></li>
            <li><a href="/main-website/partnerships" class="hover:text-gold-muted transition-colors">Resort Partnerships</a></li>
            <li><a href="#" class="hover:text-gold-muted transition-colors">Gift Cards</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-lg font-serif mb-4 text-white">Connect</h4>
          <p class="text-white/60 text-sm font-light mb-4">
            104, SHREEYA AMALGA, OFF SBR, AHMEDABAD<br>
            All days 11:30 AM to 09:30 PM
          </p>
          <a href="https://wa.me/1234567890?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20a%20luxury%20treatment." 
             class="inline-block text-gold-muted hover:text-white transition-colors text-sm uppercase tracking-widest">
            WhatsApp Us
          </a>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-white/5 text-center text-xs text-white/40 tracking-wider">
        &copy; {new Date().getFullYear()} Kiyora Wellness. All rights reserved.
      </div>
    </footer>
  </body>
</html>

---
import "@fontsource/cormorant-garamond/300.css";
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/600.css";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "../styles/global.css";
import {
  Menu,
  X,
  MapPin,
  Clock,
  Instagram,
  Facebook,
  MessageCircle,
  Mail,
  Phone,
} from "lucide-astro";
import { CONTACT, SOCIAL_LINKS, ADDRESS } from "../constants/contact";
import logoImage from "../assets/images/logo.png";
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Premium Japanese Wellness & Spa Experience" } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/png"
      href={`${import.meta.env.BASE_URL}favicon.png`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Kiyora Wellness</title>
    <meta name="description" content={description} />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Header -->
    <header
      class="fixed w-full z-50 transition-all duration-300 bg-charcoal-900/90 backdrop-blur-md border-b border-white/5"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <a href={`${import.meta.env.BASE_URL}`} class="block">
          <img src={logoImage.src} alt="Kiyora" class="h-12 w-auto" />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex gap-8 items-center">
          <!-- <a
            href={`${import.meta.env.BASE_URL}`}
            class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors"
            >Home</a
          > -->
          <a
            href={`${import.meta.env.BASE_URL}rituals`}
            class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors"
            >Rituals</a
          >
          <a
            href={`${import.meta.env.BASE_URL}partnerships`}
            class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors"
            >Partnership</a
          >
          <a
            href={`${import.meta.env.BASE_URL}about-us`}
            class="text-sm uppercase tracking-widest hover:text-gold-muted transition-colors"
            >About Us</a
          >
          <a
            href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20a%20luxury%20treatment.`}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-2 border border-gold-muted text-gold-muted hover:bg-gold-muted hover:text-charcoal-900 transition-colors uppercase text-sm tracking-widest"
          >
            Book
          </a>
        </nav>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="md:hidden p-2 text-white hover:text-gold-muted transition-colors"
          aria-label="Toggle Menu"
        >
          <Menu class="w-6 h-6" id="menu-icon-open" />
          <X class="w-6 h-6 hidden" id="menu-icon-close" />
        </button>
      </div>
    </header>

    <!-- Mobile Navigation Overlay -->
    <div
      id="mobile-menu"
      class="fixed inset-0 bg-charcoal-900/98 backdrop-blur-xl z-40 hidden flex-col items-center justify-center transition-all duration-300 opacity-0 pointer-events-none pt-24 pb-12 overflow-y-auto"
    >
      <nav class="flex flex-col gap-10 items-center text-center w-full px-6 my-auto">
        <a
          href={`${import.meta.env.BASE_URL}rituals`}
          class="text-lg font-light uppercase tracking-[0.2em] text-white hover:text-gold-muted transition-colors mobile-nav-link"
          >Rituals</a
        >
        <a
          href={`${import.meta.env.BASE_URL}partnerships`}
          class="text-lg font-light uppercase tracking-[0.2em] text-white hover:text-gold-muted transition-colors mobile-nav-link"
          >Partnership</a
        >
        <a
          href={`${import.meta.env.BASE_URL}about-us`}
          class="text-lg font-light uppercase tracking-[0.2em] text-white hover:text-gold-muted transition-colors mobile-nav-link"
          >About Us</a
        >
        <div class="mt-4">
          <a
            href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20a%20luxury%20treatment.`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-4 border border-gold-muted text-gold-muted hover:bg-gold-muted hover:text-charcoal-900 transition-colors uppercase text-xs font-medium tracking-[0.2em] mobile-nav-link"
          >
            Book Now
          </a>
        </div>
      </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-grow pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-charcoal-800 border-t border-white/5 pt-16 pb-8">
      <div
        class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left"
      >
        <div>
          <a href={`${import.meta.env.BASE_URL}`} class="block">
            <img src={logoImage.src} alt="Kiyora" class="h-8 w-auto" />
          </a>
          <p class="text-white/60 text-sm leading-relaxed font-light mt-4">
            Experience Luxury Defined by Japanese Rituals
          </p>
        </div>
        <div class="text-center">
          <h4 class="text-2xl font-serif mb-4 text-white">EXPERIENCE</h4>
          <ul class="space-y-2 text-sm text-white/60 font-light">
            <li>
              <a
                href={`${import.meta.env.BASE_URL}rituals`}
                class="hover:text-gold-muted transition-colors">Our Rituals</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}partnerships`}
                class="hover:text-gold-muted transition-colors"
                >Partner with us</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}about-us`}
                class="hover:text-gold-muted transition-colors">About Us</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h4 class="text-2xl font-serif mb-4 text-white">VISIT US</h4>
          <div class="text-white/60 text-sm font-light mb-4 space-y-3">
            <a
              href={ADDRESS.MAP_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start gap-2 hover:text-gold-muted transition-colors"
            >
              <MapPin class="w-4 h-4 mt-0.5 flex-shrink-0" />
              <span class="text-left">{ADDRESS.TEXT}</span>
            </a>
            <div class="flex items-center gap-2">
              <Clock class="w-4 h-4 flex-shrink-0" />
              <span>All days 11:30 AM to 09:30 PM</span>
            </div>
          </div>
          <div class="flex items-center gap-4 text-white/60">
            <a
              href={SOCIAL_LINKS.INSTAGRAM}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-gold-muted transition-colors"
              aria-label="Instagram"
            >
              <Instagram class="w-5 h-5" />
            </a>
            <a
              href={SOCIAL_LINKS.FACEBOOK}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-gold-muted transition-colors"
              aria-label="Facebook"
            >
              <Facebook class="w-5 h-5" />
            </a>
            <a
              href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}`}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-gold-muted transition-colors"
              aria-label="WhatsApp"
            >
              <MessageCircle class="w-5 h-5" />
            </a>
            <a
              href={`mailto:${CONTACT.EMAIL}`}
              class="hover:text-gold-muted transition-colors"
              aria-label="Email"
            >
              <Mail class="w-5 h-5" />
            </a>
            <a
              href={`tel:${CONTACT.PHONE}`}
              class="hover:text-gold-muted transition-colors"
              aria-label="Phone"
            >
              <Phone class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>
      <div
        class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-white/5 text-center text-xs text-white/40 tracking-wider"
      >
        &copy; {new Date().getFullYear()} Kiyora Wellness. All rights reserved.
      </div>
    </footer>

    <script>
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIconOpen = document.getElementById('menu-icon-open');
      const menuIconClose = document.getElementById('menu-icon-close');
      const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

      let isMenuOpen = false;

      function toggleMenu() {
        isMenuOpen = !isMenuOpen;
        
        if (isMenuOpen) {
          mobileMenu?.classList.remove('hidden');
          // small delay to allow display:block to apply before animating opacity
          setTimeout(() => {
            mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
            mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
          }, 10);
          
          menuIconOpen?.classList.add('hidden');
          menuIconClose?.classList.remove('hidden');
          document.body.style.overflow = 'hidden'; // Prevent scrolling
        } else {
          mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
          mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
          
          setTimeout(() => {
            mobileMenu?.classList.add('hidden');
          }, 300); // match transition duration
          
          menuIconOpen?.classList.remove('hidden');
          menuIconClose?.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }

      mobileMenuButton?.addEventListener('click', toggleMenu);
      
      // Close menu when a link is clicked
      mobileNavLinks.forEach(link => {
        link.addEventListener('click', () => {
          if (isMenuOpen) toggleMenu();
        });
      });
    </script>
  </body>
</html>

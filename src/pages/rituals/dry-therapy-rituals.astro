---
import Layout from "../../layouts/Layout.astro";
import { CONTACT } from "../../constants/contact";
import dryCover from "../../assets/images/dry-cover.jpg";
import dryInner from "../../assets/images/dry-inner.jpg";
const therapies = [
  {
    title: "Sei Zen Back & Shoulder Release",
    description:
      "Sei = Balance. A focused 30-minute therapy to relieve stiffness and tension in the back and shoulders, restoring comfort and ease.",
    prices: [{ duration: "30 Min", price: "₹1299" }],
  },
  {
    title: "Atama & Kubi Calm Touch",
    description:
      "Atama = Head | Kubi = Neck. A soothing head and neck massage designed to ease stress, reduce headaches, and relax the nervous system.",
    prices: [{ duration: "30 Min", price: "₹1299" }],
  },
  {
    title: "Ashi Revive Reflexology",
    description:
      "Ashi = Feet. A revitalizing foot reflexology treatment that stimulates pressure points to improve circulation and reduce fatigue.",
    prices: [{ duration: "30 Min", price: "₹1299" }],
  },
  {
    title: "Ki Flow Dry Therapy",
    description:
      "Ki = Life energy. A revitalizing dry massage focused on stimulating energy pathways to reduce fatigue and promote natural body healing.",
    prices: [{ duration: "60 Min", price: "₹1699" }],
  },
  {
    title: "Takumi Stretch Therapy",
    description:
      "Takumi = Skilled craftsmanship. A precision-based dry therapy combining pressure and assisted stretching to enhance flexibility and muscular relief.",
    prices: [{ duration: "60 Min", price: "₹1699" }],
  },
];
---

<Layout title="Zen Dry Therapies | Restore Your Vital Flow">
  <section
    class="pt-40 pb-20 bg-charcoal-900 border-b border-white/5 relative overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <img
        src={dryCover.src}
        alt="Zen Dry Therapies Rituals"
        class="w-full h-full object-cover object-[center_25%] opacity-90"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-charcoal-900/80 via-charcoal-900/50 to-charcoal-900"
      >
      </div>
    </div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-gold-muted/10 via-charcoal-900 to-charcoal-900 z-0"
    >
    </div>
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10 fade-in">
      <a
        href={`${import.meta.env.BASE_URL}/rituals`}
        class="text-gold-muted text-sm uppercase tracking-widest hover:text-white transition-colors mb-8 inline-block"
        >&larr; Back to Rituals</a
      >
      <h1
        class="text-5xl md:text-6xl font-serif text-white mb-6 tracking-wider"
      >
        Zen Dry Therapies
      </h1>
      <p class="text-xl text-white/60 font-light">
        Restore Your Vital Flow without the use of oils.
      </p>
    </div>
  </section>

  <section class="py-24 bg-cream text-charcoal-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left Side: Base Image -->
        <div
          class="relative h-[50vh] lg:h-auto bg-charcoal-900 overflow-hidden shadow-2xl lg:sticky lg:top-24 lg:self-start lg:min-h-[80vh]"
        >
          <img
            src={dryInner.src}
            alt="Zen Dry Therapies"
            class="absolute inset-0 w-full h-full object-cover opacity-80 duration-700 hover:scale-105"
          />
          <div
            class="absolute inset-0 border border-gold-muted/30 m-4 rounded-sm pointer-events-none"
          >
          </div>
        </div>

        <!-- Right Side: Treatments Menu -->
        <div class="space-y-16">
          {
            therapies.map((therapy) => (
              <div class="fade-in border-b border-charcoal-900/10 pb-12 last:border-0 last:pb-0">
                <h2 class="text-3xl font-serif mb-4 uppercase tracking-wider">
                  {therapy.title}
                </h2>

                <p class="text-lg font-light leading-relaxed text-charcoal-800 mb-8">
                  {therapy.description}
                </p>

                <div class="flex flex-wrap gap-4">
                  {therapy.prices.map((p) => (
                    <a
                      href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20the%20${encodeURIComponent(therapy.title)}%20(${encodeURIComponent(p.duration)}%20-%20${encodeURIComponent(p.price)}).`}
                      class="group relative border border-charcoal-900/20 bg-transparent hover:border-gold-muted transition-colors overflow-hidden flex items-center px-6 py-3 cursor-pointer justify-center"
                    >
                      <div class="absolute inset-0 bg-gold-muted/5 translate-y-full group-hover:translate-y-0 transition-transform duration-300" />

                      <div class="relative z-10 flex items-center gap-3">
                        <span class="block text-sm tracking-wider uppercase text-charcoal-800/80">
                          {p.duration}
                        </span>
                        <span class="w-1 h-1 rounded-full bg-gold-muted/50" />
                        <span class="block text-sm tracking-wider uppercase text-charcoal-800/80">
                          {p.price}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { CONTACT } from "../constants/contact";
import homeImage from "../assets/images/home-inner.jpg";
import bgImage from "../assets/images/bg-1.jpg";
---

<Layout title="Home">
  <!-- Hero Section -->
  <section
    class="relative min-h-screen flex items-center justify-center overflow-hidden bg-charcoal-900"
  >
    <div class="absolute inset-0 z-0">
      <img
        src={bgImage.src}
        alt="Kiyora Wellness Hero Background"
        class="w-full h-full object-cover opacity-90"
        loading="eager"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-charcoal-800/40 via-charcoal-900/60 to-charcoal-900"
      >
      </div>
    </div>
    <!-- Decorative subtle gradient orb -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gold-muted/5 rounded-full blur-3xl mix-blend-screen pointer-events-none"
    >
    </div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto fade-in">
      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-serif text-white mb-6 tracking-wider"
      >
        The Art of <span class="text-gold-light italic">Takumi</span>
      </h1>
      <p
        class="text-lg md:text-2xl text-white/80 font-light mb-12 max-w-2xl mx-auto leading-relaxed delay-200 fade-in"
      >
        Rooted in the Japanese concept of 'Ki'. Balance spirit, clear the mind,
        and restore inner harmony through intentional touch.
      </p>

      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-6 delay-300 fade-in"
      >
        <a
          href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}?text=Hello%20Kiyora%20Wellness%2C%20I%20would%20like%20to%20book%20a%20luxury%20treatment.`}
          class="group relative px-8 py-4 bg-gold-muted text-charcoal-900 font-medium uppercase tracking-widest text-sm overflow-hidden transition-all hover:bg-white"
        >
          <span class="relative z-10">Book Your Ritual</span>
        </a>
        <a
          href={`${import.meta.env.BASE_URL}/rituals`}
          class="px-8 py-4 border border-white/20 text-white hover:border-gold-muted hover:text-gold-muted transition-colors uppercase tracking-widest text-sm"
        >
          Explore Rituals
        </a>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="py-32 bg-cream text-charcoal-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <h2 class="text-4xl md:text-5xl font-serif">
            Curated Journeys of <br />'Sei' and 'Ki'
          </h2>
          <div class="w-12 h-px bg-gold-muted"></div>
          <p class="text-lg font-light leading-relaxed text-charcoal-800">
            Our luxury treatments are designed to provide a holistic escape from
            the everyday. Using premium natural ingredients, skilled techniques,
            and a deeply calming atmosphere, Kiyora Wellness elevates the
            standard of personal rejuvenation.
          </p>
          <a
            href={`${import.meta.env.BASE_URL}/rituals`}
            class="inline-block text-gold-muted font-medium uppercase tracking-widest hover:text-charcoal-900 transition-colors border-b border-gold-muted pb-1"
          >
            Discover Our Collection &rarr;
          </a>
        </div>
        <!-- Philosophy Section Image -->
        <div
          class="aspect-[4/5] bg-charcoal-900 rounded-sm relative overflow-hidden shadow-2xl group"
        >
          <img
            src={homeImage.src}
            alt="Luxury Wellness Treatment"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
          />
          <div
            class="absolute inset-0 bg-charcoal-900/20 group-hover:bg-transparent transition-colors duration-700"
          >
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

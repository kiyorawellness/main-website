---
import Layout from '../layouts/Layout.astro';
import { CONTACT } from "../constants/contact";
import dryRitualImage from "../assets/images/dry-ritual.jpg";
import oilRitualImage from "../assets/images/oil-ritual.jpg";
import scrubRitualImage from "../assets/images/scrub-ritual.jpg";
import coupleRitualImage from "../assets/images/couple-ritual.jpg";
import ritualsHeader from "../assets/images/rituals-header.jpg";
const therapies = [
  {
    title: "Dry Therapy Rituals",
    description: "Revitalize your 'Ki' (Life Energy) without oil. Experience Ashi Reflexology or Takumi Stretch Therapy to stimulate pressure points, reduce fatigue, and promote natural body healing.",
    price: "₹1299 Onwards",
    category: "Dry Therapies",
    features: ["Ashi Reflexology", "Takumi Stretch Therapy"],
    slug: "dry-therapy-rituals",
    img: dryRitualImage.src
  },
  {
    title: "Signature Oil Therapy Rituals",
    description: "Restore harmony with Sakura Swedish Flow or Kanso Balinese massage. We use warm herbal oils and flowing strokes to soothe tired muscles and create deep physical and mental relaxation.",
    price: "₹2299 Onwards",
    category: "Oil Therapies",
    features: ["Sakura Swedish Flow", "Kanso Balinese", "Herbal Oils"],
    slug: "signature-oil-therapy-rituals",
    img: oilRitualImage.src
  },
  {
    title: "Skin Renewal Rituals",
    description: "Reveal your natural radiance with the Midori Renewal Scrub or Sakura Glow Polish. These gentle exfoliation rituals use premium natural ingredients to remove dead cells and leave skin soft and hydrated.",
    price: "₹4999 Onwards",
    category: "Scrubs & Polish Therapies",
    features: ["Midori Renewal Scrub", "Sakura Glow Polish"],
    slug: "skin-renewal-rituals",
    img: scrubRitualImage.src
  },
  {
    title: "Couple Wellness Rituals",
    description: "Celebrate togetherness with our signature Kiyora Eternal Bliss Ritual. Begin with a romantic private jacuzzi soak followed by a synchronized full-body oil massage to deepen your emotional connection.",
    price: "₹1999 Onwards",
    category: "Couple Therapies",
    features: ["Private Jacuzzi", "Synchronized Massage"],
    slug: "couple-wellness-rituals",
    img: coupleRitualImage.src
  }
];
---

<Layout title="Spa Menu & Rituals">
  <!-- Header -->
  <section class="relative h-[40vh] min-h-[500px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src={ritualsHeader.src}
        alt="Kiyora Spa Rituals"
        class="w-full h-full object-cover object-[center_65%] opacity-90"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-charcoal-900/80 via-charcoal-900/50 to-charcoal-900"
      >
      </div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto mt-20 fade-in">
      <h1 class="text-5xl md:text-6xl font-serif text-white mb-6 tracking-wider leading-tight">
        The Kiyora Collection
      </h1>
      <p class="text-xl md:text-2xl text-white/90 font-light font-serif italic max-w-2xl mx-auto">
        Curated journeys of 'Sei' (Balance) and 'Ki' (Energy). 
      </p>
    </div>
  </section>

  <!-- Grid Menu -->
  <section class="py-24 bg-charcoal-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-24">
        {therapies.map((therapy, index) => (
          <div class={`flex flex-col ${index % 2 !== 0 ? '' : ''} fade-in delay-${(index % 3) * 100}`}>
            <!-- Therapy image for treatment -->
            <a href={`${import.meta.env.BASE_URL}/rituals/${therapy.slug}`} class="block w-full aspect-video bg-charcoal-800 mb-8 relative overflow-hidden group">
               <img src={therapy.img} alt={therapy.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
               <div class="absolute inset-0 bg-gradient-to-t from-charcoal-950/40 to-transparent transition-opacity group-hover:opacity-30"></div>
            </a>
            
            <div class="flex items-start justify-between mb-4">
              <a href={`${import.meta.env.BASE_URL}/rituals/${therapy.slug}`} class="group">
                <h3 class="text-3xl font-serif text-white group-hover:text-gold-muted transition-colors">{therapy.title}</h3>
              </a>
            </div>
            <p class="text-gold-muted text-sm uppercase tracking-widest mb-4">{therapy.category}</p>
            <p class="text-white/70 font-light leading-relaxed mb-8 flex-grow">
              {therapy.description}
            </p>
            
            <div class="flex items-center justify-between">
              <span class="text-white text-lg font-serif">{therapy.price}</span>
              <a href={`${import.meta.env.BASE_URL}/rituals/${therapy.slug}`} 
                 class="text-sm text-gold-muted uppercase tracking-widest hover:text-white transition-colors">
                Explore Details &rarr;
              </a>
            </div>
            <div class="border-b border-white/10 mt-4"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Memberships CTA -->
  <section class="py-24 bg-cream text-charcoal-900 text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-4xl font-serif mb-6">Kiyora Memberships</h2>
      <p class="text-lg font-light mb-10 text-charcoal-800">
        Elevate your lifestyle with our exclusive wellness plans. Enjoy priority booking, guaranteed rates, and complimentary add-ons.
      </p>
      <a href={`https://wa.me/${CONTACT.WHATSAPP_NUMBER}?text=Hello%2C%20I%20want%20to%20know%20more%20about%20Memberships`} 
         class="inline-block px-8 py-4 bg-charcoal-900 text-gold-muted font-medium uppercase tracking-widest hover:bg-charcoal-800 transition-colors">
        Inquire About Plans
      </a>
    </div>
  </section>
</Layout>
